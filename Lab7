class Vehicle :
    def __int__(self,vid,model,year):
        self.vid=vid
        self.model=model
        self.year=year

    def __str__(self):
        return f"ID: {self.vid}, Model: {self.model}, Year: {self.year}"

    def __eq__(self, other):
        return self.vid== other.vid

    def is_new(self, n):
        return self.year >= 2026 - n

class Car(Vehicle):
    def __init__(self,vid,model,year, fuel_type, doors):
        super().__init__(vid,model,year)
        self.fuel_type = fuel_type
        self.doors = doors

    def __str__(self):
        return f"Car - ID: {self.vid}, Model: {self.model}, Year: {self.year}"
class Truck(Vehicle):
    def __init__(self,vid,model,year,max_load,axles):
        super().__init__(vid,model,year)
        self.max_load=max_load
        self.axles=axles

    def __str__(self):
        return f"Truck - ID: {self.vid}, Model: {self.model}, Year : {self.year}"

class Motorcycle(Vehicle):
    def __init__(self,vid,model,year,engine_cc,type):
        super().__init__(vid,model,year)
        self.engine_cc=engine_cc
        self.type=type

    def __str__(self):
        return f"Motor - ID: {self.vid}, Model: {self.model}, Year: {self.year} "

def save_fleet_to_file(vehicles, filename):
    with open(filename, "w") as file:
        for vehicle in vehicles:
            if isinstance(vehicle, Car):
                file.write(f"Car,{vehicle.vid}, {vehicle.model}, {vehicle.year}, {vehicle.fuel_type}, {vehicle.doors}\n")
            elif isinstance(f"Truck {vehicle.vid}, {vehicle.model}, {vehicle.year}, {vehicle.max_load}, {vehicle.axles}\n")

            elif isinstance(f"Motorcycle, {vehicle.vid} ,{vehicle.model}, {vehicle.year}, {vehicle.engine_cc}, {vehicle.type}\n")

def load_fleet_to_file(vehicles, filename) :
    vehicles = []

    with open(filename , "r") as file:
        for line in file:
            data = line.strip().split(",")

            vehicle_type = data[0]
            vid = data[1]
            model = data[2]
            year = data[3]

            if vehicle_type == "Car" :
                fuel_type = data[4]
                doors = int(data[5])
                vehicles.append(Car(vid, model, year, fuel_type, doors))

            elif vehicle_type == "Truck" :
                max_load = int(data[4])
                axles = int(data[5])
                vehicles.append(Car(vid, model, year, max_load, axles))

            elif vehicle_type == "Car" :
                fuel_type = data[4]
                doors = int(data[5])
                vehicles.append(Car(vid, model, year, fuel_type, doors))

            if vehicle_type == "Motorcycle" :
                engine_cc = data[4]
                type = int(data[5])
                vehicles.append(Car(vid, model, year, engine_cc, type))

    return vehicles
